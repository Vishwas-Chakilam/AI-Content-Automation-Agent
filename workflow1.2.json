    {
      "parameters": {
        "promptType": "define",
        "text": "=Create a slug, blog post title, meta description, and SEO labels for the following topic:\n\nTitle: {{ $json.title }}\nDescription: {{ $json.description }}\n\nSlug Guidelines:\n- Keep it concise (4-5 words maximum)\n- Include primary keyword related to technology\n- Use hyphens\n- Avoid unnecessary words\n\nTitle Guidelines:\n- No colon (:)\n- Include primary keyword\n- 50–60 characters\n- Clear and engaging\n\nMeta Description Guidelines:\n- 150–160 characters\n- Include keywords naturally\n- Action-oriented and engaging\n- Reflect blog content accurately\n\nLabels Guidelines:\n- Generate 3 to 5 SEO-friendly labels\n- Each label should be 1–3 words only\n- Focus on technology topics\n- Avoid long sentences\n\nOutput format:\nReturn ONLY a valid JSON object with these fields:\nslug, title, meta, labels\n\nExample:\n{\n  \"slug\": \"ai-healthcare-revolution\",\n  \"title\": \"AI Transforming Healthcare in 2024\",\n  \"meta\": \"Explore how AI is revolutionizing medical diagnostics...\",\n  \"labels\": [\"AI\", \"Healthcare\", \"Technology\"]\n}",
        "options": {
          "systemMessage": "You are an SEO content strategist specializing in Technology, IT and Corporate topics. Use a Professional Peer tonality - be concise and efficient."
        }
      },
      "id": "f16a6603-9703-48b9-bb9a-d759c2993169",
